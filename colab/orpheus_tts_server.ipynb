      "source": [
        "# 4) Start the server in the background.\n",
        "# First launch downloads the Orpheus model (~6 GB) — takes a few minutes.\n",
        "import subprocess, sys, time, urllib.request\n",
        "\n",
        "proc = subprocess.Popen(\n",
        "    [sys.executable, SERVER],\n",
        "    stdout=open(\"server.log\", \"w\"),\n",
        "    stderr=subprocess.STDOUT,\n",
        ")\n",
        "\n",
        "print(\"Waiting for the server (model download on first run)...\")\n",
        "for i in range(600):\n",
        "    try:\n",
        "        with urllib.request.urlopen(\"http://localhost:8000/health\", timeout=2) as r:\n",
        "            print(\"Server ready:\", r.read().decode())\n",
        "            break\n",
        "    except Exception:\n",
        "        if proc.poll() is not None:\n",
        "            print(open(\"server.log\").read()[-3000:])\n",
        "            raise RuntimeError(\"server crashed — log above\")\n",
        "        time.sleep(2)\n",
        "else:\n",
        "    raise TimeoutError(\"server never came up — check server.log\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "HlEZTquzE8HX"
      },
      "outputs": [],
      "source": [
        "# 5) Sanity check: synthesize a line and play it right here\n",
        "import json, struct, urllib.request\n",
        "import numpy as np\n",
        "from IPython.display import Audio, display\n",
        "\n",
        "req = urllib.request.Request(\n",
        "    \"http://localhost:8000/tts\",\n",
        "    data=json.dumps({\"text\": \"Hey! I'm running on a Colab GPU now.\", \"voice\": \"tara\"}).encode(),\n",
        "    headers={\"Content-Type\": \"application/json\"},\n",
        ")\n",
        "t0 = __import__(\"time\").time()\n",
        "raw = urllib.request.urlopen(req).read()\n",
        "pcm = np.frombuffer(raw[: len(raw) // 4 * 4], dtype=\"<f4\")\n",
        "print(f\"{len(pcm)/24000:.1f}s of audio in {__import__('time').time()-t0:.1f}s\")\n",
        "display(Audio(pcm, rate=24000))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "dy8KekiFE8HX"
      },
      "outputs": [],
      "source": [
        "# 6) Open a public tunnel (free, no account) and print the Mac command\n",
        "import re, subprocess, time\n",
        "\n",
        "!wget -q -nc https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -O cloudflared\n",
        "!chmod +x cloudflared\n",
        "\n",
        "tunnel = subprocess.Popen(\n",
        "    [\"./cloudflared\", \"tunnel\", \"--url\", \"http://localhost:8000\", \"--no-autoupdate\"],\n",
        "    stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,\n",
        ")\n",
        "url = None\n",
        "deadline = time.time() + 60\n",
        "while time.time() < deadline and url is None:\n",
        "    line = tunnel.stdout.readline()\n",
        "    m = re.search(r\"https://[a-z0-9-]+\\.trycloudflare\\.com\", line or \"\")\n",
        "    if m:\n",
        "        url = m.group(0)\n",
        "assert url, \"tunnel URL never appeared — rerun this cell\"\n",
        "\n",
        "print(\"Tunnel is up! On your Mac, run:\\n\")\n",
        "print(f\"  ORPHEUS_LIVE_TTS_BACKEND=remote \\\\\\n  ORPHEUS_LIVE_TTS_REMOTE_URL={url} \\\\\\n  make run\")\n",
        "print(\"\\nKeep this notebook running for the whole conversation.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "o988SAToE8HX"
      },
      "source": [
        "### Notes\n",
        "\n",
        "- **Keep this tab open** — Colab kills idle runtimes; the free tier disconnects after ~90 min idle.\n",
        "- The tunnel URL changes every session; rerun cell 6 and update the env var on the Mac.\n",
        "- First request after startup is slower (CUDA warmup); it settles after one or two sentences.\n",
        "- A T4 is roughly realtime for Orpheus; with it, you can flip `ORPHEUS_LIVE_TTS_STREAMING=1`\n",
        "  on the Mac for lower first-audio latency. If you hear chop, leave streaming off.\n",
        "- This reference server uses plain `transformers` generation. For H100-class latency\n",
        "  (~150 ms first audio), swap in vLLM per `canopyai/Orpheus-TTS` — the HTTP contract is identical."
      ]
    }

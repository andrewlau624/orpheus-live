        "REPO_URL = \"https://github.com/andrewlau624/orpheus-live\"  # e.g. \"https://github.com/<you>/orpheus-live.git\"\n",
        "\n",
        "if REPO_URL:\n",
        "    !rm -rf orpheus-live && git clone --depth 1 $REPO_URL orpheus-live\n",
